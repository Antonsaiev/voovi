# Nginx entrypoint
NGINX_HTTP_PORT=80

# Direct local ports for debugging services without nginx
VOOVI_WEB_PORT=8080
SVOOVI_API_PORT=7005
ANALITIC_PORT=7000
PHPMYADMIN_PORT=8081
MYSQL_PORT=3308

# Local MySQL/MariaDB
MYSQL_HOST=db
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=voovi
MYSQL_USER=voovi.ru
MYSQL_PASSWORD=voovi.ru
MYSQL_DUMP_FILE=/dump/voovi.sql

# PHP application database settings
DB_HOST=db
DB_LOGIN=voovi.ru
DB_PASSWORD=voovi.ru
DB_NAME=voovi

# Local URLs routed through nginx
VOOVI_MAIN_HOST=voovi.localhost
VOOVI_MAIN_SCHEME=http
VOOVI_DOC_HOST=analitic.voovi.localhost
VOOVI_DOC_SCHEME=http
VOOVI_ANALITIC_HOST=analitic.voovi.localhost
VOOVI_ANALITIC_SCHEME=http
VOOVI_COOKIE_DOMAIN=voovi.localhost
HOST_VOOVI=http://voovi.localhost
api_s_voovi=http://apisvoovi:8000
api_s_voovi_host=http://s.voovi.localhost

# Django applications
DEBUG=1
SECRET_KEY=change-me-local-dev-only
ALLOWED_HOSTS="voovi.localhost s.voovi.localhost analitic.voovi.localhost django.voovi.localhost localhost 127.0.0.1 0.0.0.0 apisvoovi svoovi-api analitic s.voovi.ru voovi.ru"
SQL_ENGINE=django.db.backends.mysql
SQL_DATABASE=voovi
SQL_USER=voovi.ru
SQL_PASSWORD=voovi.ru
SQL_HOST=db
SQL_PORT=3306
MIDDLEWARE="django.middleware.security.SecurityMiddleware django.contrib.sessions.middleware.SessionMiddleware django.middleware.common.CommonMiddleware django.middleware.csrf.CsrfViewMiddleware django.contrib.auth.middleware.AuthenticationMiddleware django.contrib.messages.middleware.MessageMiddleware django.middleware.clickjacking.XFrameOptionsMiddleware middleware.middleware.AuthCooke middleware.middleware.Dostup"

# phpMyAdmin
PMA_HOST=db
UPLOAD_LIMIT=512M

PHP_DATE_TIMEZONE=Europe/Moscow
